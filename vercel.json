{
  "version": 2,
  "builds": [
    {
      "src": "hospital_managment/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.12" }
    }
    ,
    {
      "src": "staticfiles/**",
      "use": "@vercel/static"
    }
    ,
    {
      "src": "media/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "hospital_managment/wsgi.py"
    }
  ]
}